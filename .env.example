# Environment Configuration - COPY AND FILL IN YOUR VALUES
# This file is committed to git as a template
# Each developer creates a local .env file based on this

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Connection
DATABASE_URL=mongodb://localhost:27017/logitrack

# JWT Security - MUST BE MIN 32 CHARACTERS FOR PRODUCTION
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=12h
