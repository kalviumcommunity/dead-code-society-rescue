# LogiTrack Backend Environment Configuration
# Copy this file to .env and fill in your values
# IMPORTANT: .env is in .gitignore and will NOT be committed

# Server Configuration
# The port where the Express server will listen
PORT=3000

# Environment mode: development or production
# In production, error messages are not leaked to clients
NODE_ENV=development

# Database Configuration
# Format: mongodb://[username]:[password]@[host]:[port]/[database]
# For local development: mongodb://localhost:27017/logitrack
# For MongoDB Atlas: mongodb+srv://user:password@cluster.mongodb.net/database
DATABASE_URL=mongodb://localhost:27017/logitrack

# JWT Secret Configuration
# CRITICAL: Use a random string of at least 32 characters
# In production, use a cryptographically secure random string
# Generate one with: openssl rand -hex 32
# Example: 3d6f45a9b8c2e1f7d9a4b5c6e8f1a2b3d4c5e6f7g8h9i0j1k2l3m4n5o6p7q8
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long-change-this-in-production
